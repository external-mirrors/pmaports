# Forked from Alpine - temporarily build branch for testing
maintainer="YOUR NAME <EMAIL@ADDRESS.COM>"
pkgname=usb-signaller
pkgver=0.3.1_git20260721
_commit="a8d8b03664fd06366bc1af165f948b70cb7842b2"
pkgrel=0
pkgdesc="Switch between different USB gadgets"
url="https://codeberg.org/DylanVanAssche/usb-signaller"
arch="all"
license="GPL-3.0-or-later"
source="
$pkgname-$_commit.tar.gz::https://codeberg.org/DylanVanAssche/usb-signaller/archive/$_commit.tar.gz
	usb-signaller.initd
"
makedepends="cargo-auditable dbus-dev"
subpackages="$pkgname-systemd $pkgname-openrc"
builddir="$srcdir/$pkgname"

prepare() {
	default_prepare
	cargo fetch --target="$CHOST" --locked
}

build() {
	cargo auditable build --release --frozen
}

check() {
	cargo test --frozen
}

package() {
	install -Dm755 target/release/usb-signaller "$pkgdir"/usr/bin/usb-signaller

	# Init service files
	for f in "$srcdir"/usb-signaller.initd distro/openrc/*.initd; do
		install -Dm755 "$f" "$pkgdir"/etc/init.d/"$(basename "$f" .initd)"
	done

	for f in *.service distro/systemd/*.service; do
		install -Dm644 "$f" "$pkgdir"/usr/lib/systemd/system/"$(basename "$f")"
	done

	for f in distro/scripts/*.sh; do
		# service scripts/units expect no .sh extension
		install -Dm755 "$f" "$pkgdir"/usr/bin/"$(basename "$f" .sh)"
	done

	# DBus policy
	install -Dm644 com.meego.usb_moded.conf -t "$pkgdir"/usr/share/dbus-1/system.d/
}

