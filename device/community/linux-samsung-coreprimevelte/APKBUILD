665174a345a8fb844f510945670013e17eb641a1ae1c9256294155fbd829aaadc0e8fc6e8605c8985fc2aa30ca24e20d293c54a09a6793ca9f58fca12e62a544  config-samsung-coreprimevelte.aarch64
"
