maintainer="Alexander Baransky <sanyapilot496@gmail.com>"
pkgname=firmware-xiaomi-tucana
pkgver=2
pkgrel=0
pkgdesc="Firmware for Xiaomi Mi Note 10 / Mi CC9 Pro"
url="https://github.com/sm7150-mainline/firmware-xiaomi-tucana"
arch="aarch64"
license="proprietary"
options="!check !strip !archcheck !tracedeps pmb:cross-native"
_commit="f16d27c78f8c4b1542f00fd9d90457e23a831caf"
source="
	$pkgname-$_commit.tar.gz::$url/archive/$_commit/$pkgname-$_commit.tar.gz
	30-initramfs-$pkgname.files
"
builddir="$srcdir/$pkgname-$_commit"

package() {
	mv "$builddir"/lib "$builddir"/usr
	find . -type f -exec install -Dm644 {} "$pkgdir"/{} \;

	install -Dm644 "$srcdir/30-initramfs-$pkgname.files" -t \
		"$pkgdir"/usr/share/mkinitfs/files
}

