# Reference: <https://postmarketos.org/devicepkg>
# Co-Maintainer: Casey Connolly <kcxt@postmarketos.org>
# Co-Maintainer: Dylan Van Assche <me@dylanvanassche.be>
maintainer="Alexander Martinz <amartinz@shiftphones.com>"
pkgname=device-shift-axolotl
pkgdesc="SHIFT6mq"
pkgver=24
pkgrel=0
url="https://postmarketos.org"
license="MIT"
arch="aarch64"
options="!check !archcheck"
depends="
	alsa-ucm-conf-sdm845
	firmware-shift-sdm845>=20230815-r2
	fwupd>=1.8.6
	hexagonrpcd>=0.3.2-r3
	linux-postmarketos-qcom-sdm845
	make-dynpart-mappings
	mkbootimg
	postmarketos-base
	soc-qcom
	soc-qcom-modem
	soc-qcom-qbootctl
	systemd-boot
	unl0kr-fbforcerefresh
"
makedepends="devicepkg-dev"
source="
	deviceinfo
	kernel-cmdline.conf
	hexagonrpcd.confd
	modules-initfs
	q6voiced.conf
	81-libssc-shift-axolotl.rules
"
subpackages="
	$pkgname-openrc
	$pkgname-pmtest
"
replaces="device-shift-axolotl-nonfree-firmware"

build() {
	devicepkg_build $startdir $pkgname
}

package() {
	devicepkg_package $startdir $pkgname

	install -Dm644 "$srcdir"/81-libssc-shift-axolotl.rules \
		-t "$pkgdir"/usr/lib/udev/rules.d/
	install -Dm644 "$srcdir"/q6voiced.conf \
		"$pkgdir"/etc/conf.d/q6voiced
	install -Dm644 "$srcdir"/hexagonrpcd.confd \
		"$pkgdir"/usr/share/hexagonrpcd/hexagonrpcd-sdsp.conf
}

openrc() {
	default_openrc
	replaces="device-shift-axolotl-nonfree-firmware-openrc"
	install="$subpkgname.post-install $subpkgname.post-upgrade"
	depends="hexagonrpcd-openrc"

	mkdir -p "$subpkgdir"
}

pmtest() {
	depends="postmarketos-test-bootrr qrtr firmware-shift-sdm845 postmarketos-test-unl0kr"
	install_if="$pkgname=$pkgver-r$pkgrel postmarketos-mkinitfs-hook-ci"

	mkdir -p "$subpkgdir"
}

