e631f6f5c31f9ab626b19ce4257b93c7ea103fd2e4fffe8d605a97fd4d92635318252f3d15ab95e0c2548a308b6a23ec59b0828b5560981a686d712478059b28  config-postmarketos-qcom-sdm670.aarch64
"
