c7c7e901b771b2cf84df357b7604098c55b12179f919bd4deef5d54183882b0fd037ca9dd40f301c629b584b8f59d41dc49452a5ded91a545d96c35d3501be1f  config-postmarketos-rockchip.aarch64
6c633cd46a9a14db97c31e0e84fe410fccd4966affafbdfa8e511485a80a4a81b7c40deb9034e268f8401611ba3b1669eb3a5efc0bf2b96efc905a344523dccc  linux-postmarketos-rockchip-6.19.9.patch.xz
"
