From 08c2f81c6e9254305af187e7e132d97e6afe384a Mon Sep 17 00:00:00 2001
From: Stefan Hansson <newbyte@postmarketos.org>
Date: Wed, 15 Jul 2026 18:43:10 +0200
Subject: [PATCH 4/4] staging: bes2600: Fix always true statement

I am not entirely sure about the original intention behind this, but
this seems like the most likely intended logic.

Signed-off-by: Stefan Hansson <newbyte@postmarketos.org>
---
 drivers/staging/bes2600/wsm.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/drivers/staging/bes2600/wsm.c b/drivers/staging/bes2600/wsm.c
index 55a4e2b42db1..fdf8d9223cbe 100644
--- a/drivers/staging/bes2600/wsm.c
+++ b/drivers/staging/bes2600/wsm.c
@@ -1110,7 +1110,7 @@ int wsm_epta_cmd(struct bes2600_common *hw_priv, struct wsm_epta_msg *arg)
 	else if (coex_is_fdd_mode())
 		arg->hw_epta_enable |= (1 << 10); //LMAC_COEX_MODE_FDD
 
-	if (arg->hw_epta_enable != 3 || arg->hw_epta_enable != 4) { //use for wifi connect
+	if (arg->hw_epta_enable != 3 && arg->hw_epta_enable != 4) { //use for wifi connect
 		///TODO: remove this hack. use hardware in disconnect mode
 		if (coex_is_wifi_inactive()) {
 			arg->wlan_duration = 20000;
