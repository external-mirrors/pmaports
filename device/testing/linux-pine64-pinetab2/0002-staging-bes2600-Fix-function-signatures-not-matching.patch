From 5ca0c3ab0d69ae3a022c518f607beab6cc254685 Mon Sep 17 00:00:00 2001
From: Stefan Hansson <newbyte@postmarketos.org>
Date: Wed, 15 Jul 2026 18:42:04 +0200
Subject: [PATCH 2/4] staging: bes2600: Fix function signatures not matching
 prototypes

Fails to compile with LLVM otherwise.

Signed-off-by: Stefan Hansson <newbyte@postmarketos.org>
---
 drivers/staging/bes2600/epta_coex.c | 8 ++++----
 1 file changed, 4 insertions(+), 4 deletions(-)

diff --git a/drivers/staging/bes2600/epta_coex.c b/drivers/staging/bes2600/epta_coex.c
index dfdf8e70a1a2..6a00a929aa38 100644
--- a/drivers/staging/bes2600/epta_coex.c
+++ b/drivers/staging/bes2600/epta_coex.c
@@ -382,7 +382,7 @@ void coex_set_wifi_conn(struct bes2600_common *hw_priv, uint8_t connect_status)
 	}
 }
 
-bool coex_is_wifi_inactive()
+bool coex_is_wifi_inactive(void)
 {
 	bes_devel("%s, epta_conn_state:%d", __FUNCTION__, epta_conn_state);
 	return epta_conn_state == EPTA_STATE_WIFI_DISCONNECTED;
@@ -510,19 +510,19 @@ void coex_set_fdd_mode(bool fdd_mode)
 	}
 }
 
-bool coex_is_fdd_mode()
+bool coex_is_fdd_mode(void)
 {
 	bes_devel("%s, %d", __FUNCTION__, coex_fdd_mode);
 	return coex_fdd_mode;
 }
 
-bool coex_is_bt_a2dp()
+bool coex_is_bt_a2dp(void)
 {
 	bes_devel("%s, coex_bt_state:%d", __FUNCTION__, coex_bt_state);
 	return coex_bt_state == 3;
 }
 
-bool coex_is_bt_inactive()
+bool coex_is_bt_inactive(void)
 {
 	bes_devel("%s, coex_bt_state:%d", __FUNCTION__, coex_bt_state);
 	return coex_bt_state == 0;
-- 
2.52.0

