# Maintainer: Leandro Friedrich <email@leandrofriedrich.de>
# Co-Maintainer: map220v <map220v300@gmail.com>
pkgname=alsa-ucm-conf-samsung-sm7125
pkgver=1.1
pkgrel=3
pkgdesc="ALSA Use Case Manager configuration for Samsung Galaxy Phones based on Qualcomm's SM7125 SoC"
url="https://alsa-project.org"
arch="aarch64"
license="BSD-3-Clause"
source="
	HiFi.conf
	sm7125_GalaxyA52.conf
"
options="!check" # no tests
depends="alsa-ucm-conf"
replaces="alsa-ucm-conf"

package() {
	install -Dm644 "$srcdir/sm7125_GalaxyA52.conf" \
		"$pkgdir/usr/share/alsa/ucm2/conf.d/sm7125/Galaxy A52.conf"
	install -Dm644 "$srcdir/sm7125_GalaxyA52.conf" \
		"$pkgdir/usr/share/alsa/ucm2/conf.d/sm7125/Galaxy A72.conf"
	install -Dm644 "$srcdir/HiFi.conf" \
		"$pkgdir/usr/share/alsa/ucm2/Samsung/a52q/HiFi.conf"

	cd "$pkgdir/usr/share/alsa/ucm2/conf.d/sm7125"

	ln -sf "Galaxy A52.conf" samsung-SamsungGalaxyA52-.conf
}

sha512sums="
ae8b56844dc5f6a644115ee3cb9964cc7824afe8440a42415b8da4c86bc96ae7bfe705780d857fa9dbd42ba5445cfde2773da968b6b8ea91c29cba37c1928cde  HiFi.conf
a77a1805c7e384a66c11a6abf9768941920b4f0bebca7a6fe864e73e00e370788c9aab7005e5f9b03ffc100a0f6ba7017be9befcc8e0b281c99ff0bbbcc4549b  sm7125_GalaxyA52.conf
"
