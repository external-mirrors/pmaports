+	.startup = aw88261_startup,
+	.set_stream = aw88261_dai_set_stream,
+	.set_sysclk = aw88261_dai_set_sysclk,
+	.set_fmt = aw88261_dai_set_fmt,
+	.hw_params = aw88261_hw_params,
+};
