-		ret = aw88261_dev_check_mode2_pll(aw_dev);
-		if (ret) {
-			dev_err(aw_dev->dev, "mode2 check iis failed");
-			return ret;
-		}
+	if (ret == 0) {
+		dev_info(aw_dev->dev, "PLL stabilized successfully");
 	}
 
 	return ret;
