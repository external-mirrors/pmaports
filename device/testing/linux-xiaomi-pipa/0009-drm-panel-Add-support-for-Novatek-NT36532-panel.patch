From cd970caef6ef84c7d6926227e6b655976dfa2928 Mon Sep 17 00:00:00 2001
From: Arseniy Velikanov <me@adomerle.pw>
Date: Wed, 11 Feb 2026 21:05:40 +0700
Subject: [PATCH 09/12] drm/panel: Add support for Novatek NT36532 panel

Add a driver for panels using the Novatek NT36532 Display Driver IC,
including support for the CSOT panel used in the Xiaomi Pad 6 tablets.

Co-developed-by: Ryo Kenrie Wongso <developer@damillora.com>
Signed-off-by: Ryo Kenrie Wongso <developer@damillora.com>

input: nt36xxx: Enable pen support

nt36xxx: add pen input resolution

input/touchscreen: nt36523: add support for pipa in driver
---
 drivers/gpu/drm/panel/Kconfig                 |  10 +
 drivers/gpu/drm/panel/Makefile                |   1 +
 drivers/gpu/drm/panel/panel-novatek-nt36532.c | 609 ++++++++++++++++++
 drivers/input/touchscreen/nt36523/nt36xxx.c   | 331 +++++-----
 drivers/input/touchscreen/nt36523/nt36xxx.h   |  25 +-
 .../touchscreen/nt36523/nt36xxx_fw_update.c   |  81 ++-
 .../touchscreen/nt36523/nt36xxx_mem_map.h     | 340 ++++++++--
 7 files changed, 1190 insertions(+), 207 deletions(-)
 create mode 100644 drivers/gpu/drm/panel/panel-novatek-nt36532.c

diff --git a/drivers/gpu/drm/panel/Kconfig b/drivers/gpu/drm/panel/Kconfig
index 7a83804fedca..1448034ee9ce 100644
--- a/drivers/gpu/drm/panel/Kconfig
+++ b/drivers/gpu/drm/panel/Kconfig
@@ -533,6 +533,16 @@ config DRM_PANEL_NOVATEK_NT36523
 	  around the Novatek NT36523 display controller, such as some
 	  Boe panels used in Xiaomi Mi Pad 5 and 5 Pro tablets.
 
+config DRM_PANEL_NOVATEK_NT36532
+	tristate "Novatek NT36532 panel driver"
+	depends on OF
+	depends on DRM_MIPI_DSI
+	depends on BACKLIGHT_CLASS_DEVICE
+	help
+	  Say Y here if you want to enable support for the panels built
+	  around the Novatek NT36532 display controller, such as some
+	  panels used in Xiaomi Pad 6 tablets.
+
 config DRM_PANEL_NOVATEK_NT36672A
 	tristate "Novatek NT36672A DSI panel"
 	depends on OF
diff --git a/drivers/gpu/drm/panel/Makefile b/drivers/gpu/drm/panel/Makefile
index b9562a6fdcb3..479571864cc9 100644
--- a/drivers/gpu/drm/panel/Makefile
+++ b/drivers/gpu/drm/panel/Makefile
@@ -52,6 +52,7 @@ obj-$(CONFIG_DRM_PANEL_NOVATEK_NT35510) += panel-novatek-nt35510.o
