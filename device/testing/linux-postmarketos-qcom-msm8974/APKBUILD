61e14469e7997a61e461c88c1d363460c7b12bccaee5a010556fd77e6a08872e4df7c0265267e568a8ea292569ad8a68e7622b0d98d418b7d6f2c1af553087bf  config-postmarketos-qcom-msm8974.armv7
"
