# Reference: <https://postmarketos.org/devicepkg>
maintainer="Federico Amedeo Izzo <federico@izzo.pro>"
pkgname=device-motorola-dubai
pkgdesc="Motorola Edge 30"
pkgver=1
pkgrel=0
url="https://postmarketos.org"
license="MIT"
arch="aarch64"
options="!check !archcheck"
depends="
	alsa-ucm-conf-qcom-sc7280
	firmware-motorola-dubai
	firmware-qcom-adreno-a660
	hexagonrpcd>=0.3.2-r3
	linux-firmware-ath11k
	linux-firmware-qca
	make-dynpart-mappings
	mkbootimg
	postmarketos-base
	soc-qcom
	soc-qcom-modem
	soc-qcom-qbootctl
	systemd-boot
	unl0kr-fbforcerefresh
"
makedepends="devicepkg-dev"
subpackages="
	$pkgname-kernel-csot:kernel_csot
	$pkgname-kernel-tianma:kernel_tianma
"
source="
	81-libssc-motorola-dubai.rules
	deviceinfo
	kernel-cmdline.conf
	modules-initfs
"

build() {
	devicepkg_build $startdir $pkgname

	dd if=/dev/zero of="$srcdir/dtbo.img" bs=25165824 count=1
}

package() {
	devicepkg_package $startdir $pkgname

	install -Dm644 "$srcdir/dtbo.img" "$pkgdir/boot/dtbo.img"

	install -Dm644 "$srcdir"/81-libssc-motorola-dubai.rules -t \
		"$pkgdir"/usr/lib/udev/rules.d
}

kernel_csot() {
	pkgdesc="CSOT Panel. To know which panel your device uses, boot the device in fastboot mode after unlocking bootloader and read the 'Panel' string"
	depends="linux-postmarketos-qcom-sc7280"
	devicepkg_subpackage_kernel $startdir $pkgname $subpkgname
}

kernel_tianma() {
	pkgdesc="Tianma Panel. To know which panel your device uses, boot the device in fastboot mode after unlocking bootloader and read the 'Panel' string"
	depends="linux-postmarketos-qcom-sc7280"
	devicepkg_subpackage_kernel $startdir $pkgname $subpkgname
}

