# Reference: <https://postmarketos.org/devicepkg>
maintainer="Petr Vorel <petr.vorel@gmail.com>"
pkgname=device-lg-bullhead
pkgdesc="Google Nexus 5X"
pkgver=8
pkgrel=0
url="https://postmarketos.org"
license="MIT"
arch="aarch64"
depends="
	firmware-lg-bullhead
	mkbootimg
	postmarketos-base
"
makedepends="devicepkg-dev"
source="deviceinfo kernel-cmdline.conf"
subpackages="$pkgname-kernel-rev10:kernel_rev10 $pkgname-kernel-rev101:kernel_rev101"
options="!check !archcheck"

build() {
	devicepkg_build $startdir $pkgname
}

package() {
	devicepkg_package $startdir $pkgname
}

kernel_rev10() {
	pkgdesc="Nexus 5X rev 1.0 (See https://wiki.postmarketos.org/wiki/Google_Nexus_5X_(lg-bullhead)#Get_your_hardware_revision)"
	depends="linux-postmarketos-qcom-msm8994"
	devicepkg_subpackage_kernel $startdir $pkgname $subpkgname
}

kernel_rev101() {
	pkgdesc="Nexus 5X rev 1.01 (See https://wiki.postmarketos.org/wiki/Google_Nexus_5X_(lg-bullhead)#Get_your_hardware_revision)"
	depends="linux-postmarketos-qcom-msm8994"
	devicepkg_subpackage_kernel $startdir $pkgname $subpkgname
}
