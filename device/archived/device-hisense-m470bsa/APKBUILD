maintainer=""
pkgname=device-hisense-m470bsa
pkgdesc="Hisense Sero 7 Pro"
pkgver=5
pkgrel=0
url="https://postmarketos.org"
license="MIT"
arch="armv7"
options="!check !archcheck"
depends="postmarketos-base linux-hisense-m470bsa mkbootimg"
makedepends="devicepkg-dev"
source="deviceinfo kernel-cmdline.conf modules-load.conf pointercal"
subpackages="$pkgname-nonfree-firmware:nonfree_firmware"


build() {
	devicepkg_build $startdir $pkgname
}

package() {
	devicepkg_package $startdir $pkgname
	install -Dm644 "$srcdir"/pointercal \
		"$pkgdir"/etc/pointercal
}

nonfree_firmware() {
	pkgdesc="WiFi Firmware"
	depends="firmware-hisense-m470bsa"
	mkdir "$subpkgdir"
}

