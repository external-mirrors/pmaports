# Reference: <https://postmarketos.org/devicepkg>
maintainer="Antoine Martin (ayakael) <dev@ayakael.net>"
pkgname=device-clockworkpi-uconsole-rpi
pkgdesc="Clockwork Tech ClockworkPi uConsole with Raspberry Pi compute modules"
pkgver=10
pkgrel=0
url="https://postmarketos.org"
license="MIT"
arch="aarch64"
options="!archcheck !check"
depends="
	linux-clockworkpi-uconsole-rpi
	linux-firmware-brcm
	postmarketos-base
	raspberrypi-bootloader
"
makedepends="devicepkg-dev"
subpackages="
	$pkgname-openrc
	$pkgname-udev
	$pkgname-x11
"
source="
	95-vchiq-permissions.rules
	deviceinfo
	modules-initfs
	usercfg.txt
	xorg.conf
"
install="$pkgname-openrc.post-install $pkgname-openrc.post-upgrade"
provides="device-clockworkpi-uconsole-cm4=$pkgver-r$pkgrel"

build() {
	devicepkg_build $startdir $pkgname
}

package() {
	devicepkg_package $startdir $pkgname

	install -Dm644 "$srcdir"/usercfg.txt \
		-t "$pkgdir"/boot/

	# will be picked up by default_udev
	install -Dm644 "$srcdir"/95-vchiq-permissions.rules \
		-t "$pkgdir"/usr/lib/udev/rules.d/

	# dummy openrc folder for default_openrc
	mkdir -p "$pkgdir"/etc/init.d
}

x11() {
	install_if="$pkgname xorg-server"
	install -Dm644 "$srcdir"/xorg.conf \
		"$subpkgdir"/usr/share/X11/xorg.conf.d/10-monitor.conf
}
