# The group tag is just to easily find this APKBUILD by some scripts for automation
# group=kde-applications
maintainer="team/kde <bribbers@disroot.org>"
pkgname=tokodon
pkgver=99999_git20260224
pkgrel=0
_commit="d022997e20fc516f2d471be61c5147a67df74847"
pkgdesc="A Mastodon client for Plasma and Plasma Mobile"
url="https://invent.kde.org/network/tokodon/"
# armhf blocked by qt6-qtdeclarative
# riscv64, ppc64le, s390x: blocked by proposals
arch="all !armhf !riscv64 !ppc64le !s390x"
license="GPL-3.0-only AND CC0-1.0"
depends="
	kirigami
	kirigami-addons
	purpose
	"
makedepends="
	extra-cmake-modules
	kconfig-dev
	kcoreaddons-dev
	kdbusaddons-dev
	ki18n-dev
	kio-dev
	kirigami-addons-dev
	kirigami-dev
	knotifications-dev
	mpvqt-dev
	purpose-dev
	qcoro-dev
	qqc2-desktop-style-dev
	qt6-qtbase-dev
	qt6-qtdeclarative-dev
	qt6-qtdeclarative-private-dev
	qt6-qtmultimedia-dev
	qt6-qtsvg-dev
	qt6-qtwebsockets-dev
	qt6-qtwebview-dev
	qtkeychain-dev
	samurai
	"
subpackages="$pkgname-dbg $pkgname-lang"
_repo_url="https://invent.kde.org/network/tokodon.git"
source="https://nightly.postmarketos.org/plasma-mobile/sources/2026-02-24/tokodon-$_commit.tar.xz"
options="!check" # No tests

builddir="$srcdir/tokodon-$_commit"

build() {
	cmake -B build -G Ninja \
		-DCMAKE_BUILD_TYPE=RelWithDebInfo \
		-DCMAKE_INSTALL_PREFIX=/usr
	cmake --build build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

