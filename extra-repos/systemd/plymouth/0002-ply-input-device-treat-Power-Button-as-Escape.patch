From 849f39a410deec9d6bc118f3c0d6f61b4a4608aa Mon Sep 17 00:00:00 2001
From: Clayton Craft <clayton@craftyguy.net>
Date: Tue, 24 Feb 2026 17:04:18 -0800
Subject: [PATCH 1/2] ply-input-device: treat Power Button as Escape

Some devices (phones/tablets) don't have keyboards, so this treats
the Power Button key as Escape for e.g. hiding the splash.
---
 src/libply-splash-core/ply-input-device.c | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/src/libply-splash-core/ply-input-device.c b/src/libply-splash-core/ply-input-device.c
index 2e8a5a90..2a87ae31 100644
--- a/src/libply-splash-core/ply-input-device.c
+++ b/src/libply-splash-core/ply-input-device.c
@@ -131,6 +131,9 @@ apply_key_to_input_buffer (ply_input_device_t *input_device,
         case XKB_KEY_Escape:
                 ply_buffer_append_bytes (input_buffer, "\033", 1);
                 break;
+        case XKB_KEY_XF86PowerOff:
+                ply_buffer_append_bytes (input_buffer, "\033", 1);
+                break;
         case XKB_KEY_KP_Enter:
         case XKB_KEY_Return:
                 ply_buffer_append_bytes (input_buffer, "\n", 1);
