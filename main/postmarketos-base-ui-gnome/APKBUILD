maintainer="Stefan Hansson <newbyte@postmarketos.org>"
pkgname=postmarketos-base-ui-gnome
pkgver=11
pkgrel=3
pkgdesc="Meta package for shared configuration for GNOME-based UIs"
url="https://postmarketos.org"
arch="noarch"
license="GPL-3.0-or-later"
depends="
	dnsmasq
	gcr-ssh-agent
	glycin-loaders-all
	glycin-thumbnailer
	gnome-backgrounds
	gnome-bluetooth
	gnome-keyring
	gst-thumbnailers
	iio-sensor-proxy
	modemmanager
	postmarketos-artwork-wallpapers
	postmarketos-base-ui
	postmarketos-base-ui-audio
	postmarketos-base-ui-networkmanager
	power-profiles-provider
	xdg-desktop-portal-gtk
	xdg-user-dirs
	xdg-user-dirs-gtk
	xwayland
	"
source="
	00_postmarketos-base-ui-gnome.gschema.override
	10_postmarketos-green-accent.gschema.override
	50-duranium.conf
	duranium-gnome-software-stub.sh
	duranium-gnome-software-stub.desktop
	"
options="!check"
subpackages="
	$pkgname-duranium
	$pkgname-openrc
	gnome-app-provider-gnome-software:gnome_software
	gnome-app-provider-bazaar:bazaar
	"
install="$pkgname-openrc.post-install $pkgname-openrc.post-upgrade"

_pmb_recommends="
	cups
	decibels
	firefox-esr
	flatpak
	fprintd
	g4music
	gnome-calculator
	gnome-calendar
	gnome-clocks
	gnome-console
	gnome-contacts
	gnome-maps
	gnome-text-editor
	gnome-user-share
	gnome-weather
	gst-libav
	gst-plugins-bad
	gst-plugins-good
	gst-plugins-rs-dav1d
	gvfs-full
	loupe
	nautilus
	papers
	rygel
	showtime
	snapshot
	tuned-ppd
"

package() {
	depends="$depends gnome-app-provider"

	install -Dm644 -t "$pkgdir"/usr/share/glib-2.0/schemas \
		"$srcdir"/*.override
}

openrc() {
	install_if="$pkgname=$pkgver-r$pkgrel openrc"
	depends="
		apk-polkit-rs-openrc
		elogind
		elogind-openrc
		iio-sensor-proxy-openrc
		modemmanager-openrc
		networkmanager-openrc
		openrc
		polkit-elogind
	"

	mkdir "$subpkgdir"
}

duranium() {
	pkgdesc="$pkgdesc (Duranium)"
	install_if="$pkgname=$pkgver-r$pkgrel postmarketos-duranium"
	# Bash and zenity for the gnome-software stub
	depends="gnome-app-provider-bazaar bash zenity"

	install -Dm644 "$srcdir"/50-duranium.conf \
		-t "$subpkgdir"/usr/lib/kernel-cmdline.d

	install -Dm755 "$srcdir"/duranium-gnome-software-stub.sh \
		"$subpkgdir"/usr/bin/gnome-software
	install -Dm644 "$srcdir"/duranium-gnome-software-stub.desktop \
		"$subpkgdir"/usr/share/applications/org.gnome.Software.desktop
}

gnome_software() {
	pkgdesc="Provider that installs GNOME Software"
	provides="gnome-app-provider"
	provider_priority=100
	depends="gnome-software gnome-software-plugin-apk"

	mkdir -p "$subpkgdir"
}

bazaar() {
	pkgdesc="Provider that installs Bazaar"
	provides="gnome-app-provider"
	provider_priority=90
	depends="bazaar"

	mkdir -p "$subpkgdir"
}

