# Duranium: this is a stub so that the Phosh
# app "uninstall" button works. We don't actually
# ship GNOME Software and this desktop entry
# has NoDisplay=true

[Desktop Entry]
Name=Software
Comment=Add, remove or update software on this computer
# Translators: Do NOT translate or transliterate this text (this is an icon file name)!
Exec=gnome-software %U
Terminal=false
Type=Application
Categories=GNOME;GTK;System;PackageManager;
NoDisplay=true
