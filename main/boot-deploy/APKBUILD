# Maintainer: Clayton Craft <clayton@craftyguy.net>
pkgname=boot-deploy
pkgver=0.20.4_git20260108
_commit=5275fdb89efe4168ef27ef4284891e4c65371859
pkgrel=0
pkgdesc="tool for finalizing and deploying boot related files"
url="https://gitlab.postmarketos.org/postmarketOS/boot-deploy"
arch="noarch"
license="GPL-2.0-or-later"
source="
	https://gitlab.postmarketos.org/postmarketOS/boot-deploy/-/archive/$_commit/boot-deploy-$_commit.tar.gz

	os-customization
	use-busybox-sh.patch
	"
depends="generate-kernel-cmdline"
builddir="$srcdir/$pkgname-$_commit"

check() {
	./test_boot_deploy_functions.sh
}

package() {
	install -Dm755 boot-deploy -t "$pkgdir"/usr/bin
	install -Dm755 boot-deploy-functions.sh -t \
		"$pkgdir"/usr/share/boot-deploy
	install -Dm644 "$srcdir"/os-customization -t \
		"$pkgdir"/usr/share/boot-deploy

	touch boot-deploy-trigger
	install -Dm644 boot-deploy-trigger \
		"$pkgdir"/usr/share/mkinitfs-triggers/boot-deploy
}
